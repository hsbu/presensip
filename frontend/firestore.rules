rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isLecturer() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'lecturer';
    }

    // Sessions: lecturer owns, admin can read/write all
    match /sessions/{sessionId} {
      allow read: if isLecturer() || isAdmin();
      allow write: if isAdmin() ||
        (isLecturer() && request.auth.uid == resource.data.lecturerId);
    }

    // Attendance records: read by lecturer (own session) and admin; write by Cloud Function only
    match /attendanceRecords/{recordId} {
      allow read: if isLecturer() || isAdmin();
      allow write: if false; // Cloud Function service account only
    }

    // Enrollments: admin read/write; Cloud Function write
    match /enrollments/{studentId} {
      allow read, write: if isAdmin();
    }

    // Alerts: lecturer and admin read; write by Cloud Function only
    match /alerts/{alertId} {
      allow read: if isLecturer() || isAdmin();
      allow write: if false;
    }

    // User profiles: own read; admin read all; admin write all
    match /users/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow write: if isAdmin();
    }
  }
}
