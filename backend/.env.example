# Firebase service account credentials
# Get this from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"presensip-33a66",...}'

# Or use file path
SERVICE_ACCOUNT_PATH=./serviceAccount.json

# MQTT Configuration (for IoT integration - two separate ESP32 devices)
MQTT_BROKER=YOUR_HIVEMQ_HOST
MQTT_PORT=8883
MQTT_USERNAME=YOUR_HIVEMQ_USERNAME
MQTT_PASSWORD=YOUR_HIVEMQ_PASSWORD

# Topic for biometric data (face recognition ESP32)
MQTT_BIOMETRIC_TOPIC="presensip/biometric/#"

# Topic for headcount data (YOLO person detection ESP32)
MQTT_HEADCOUNT_TOPIC="presensip/headcount/#"

# HTTP ingestion (alternative to MQTT)
# Generate a random key and set it in your local .env as IOT_API_KEY
IOT_API_KEY=replace_with_a_strong_key
HTTP_PORT=3001
